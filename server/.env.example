# ========================================
# 伺服器設定
# ========================================
PORT=3000
NODE_ENV=development

# ========================================
# Azure Speech Services (STT)
# ========================================
# 取得方式: https://portal.azure.com → Azure AI services → Speech
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=japaneast

# ========================================
# HeyGen API 設定
# ========================================
# HeyGen API Key (用於生成 access token)
# 取得方式: https://app.heygen.com/settings?nav=API
HEYGEN_API_KEY=your-heygen-api-key
HEYGEN_API_URL=https://api.heygen.com/v1
USE_LIVEKIT=true

# HeyGen 直接模式設定
ENABLE_HEYGEN_DIRECT_MODE=true
# 直接模式會話超時時間（分鐘）
HEYGEN_DIRECT_SESSION_TIMEOUT=10
# 會話清理間隔（分鐘）
HEYGEN_SESSION_CLEANUP_INTERVAL=5

# HeyGen 預設 Avatar 和 Voice
# Avatar ID 取得方式: https://app.heygen.com/avatars (點擊 avatar 查看 ID)
# Voice ID 取得方式: https://app.heygen.com/voices 或使用 Azure TTS voice ID
# 前端可透過 GET /heygen-direct/config 動態取得這些值
AVATAR_ID=your-avatar-id
VOICE_ID=your-voice-id

# ========================================
# 安全性設定
# ========================================
# CORS 允許的來源 (逗號分隔)
CORS_ORIGIN=http://localhost:3000,http://localhost:8000,http://localhost:8080

# API 認證金鑰 (前端透過 x-api-key header 驗證，與 HEYGEN_API_KEY 不同)
# 前端配置檔中的 avaterApiKey 應對應此值
API_KEY=your-api-key
